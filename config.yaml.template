# QMind 配置模板
# 复制为 config.yaml 并填写 API Key

llm:
  default_model: claude-sonnet-4-6
  # 环境变量方式设置 API Key（推荐）:
  #   ANTHROPIC_API_KEY=sk-...
  #   OPENAI_API_KEY=sk-...
  #   DEEPSEEK_API_KEY=sk-...

execution:
  dry_run: true
  default_exchange: binance

storage:
  db_path: qmind.db

logging:
  level: INFO

notification:
  type: none       # none / feishu / email
  # webhook_url: "https://open.feishu.cn/open-apis/bot/v2/hook/..."

# 交易所 API 配置（dryRun 模式下不需要）
# exchange:
#   binance:
#     api_key: ""
#     api_secret: ""
